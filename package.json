{
  "name": "pixel-agents",
  "displayName": "Pixel Agents",
  "description": "Pixel art office where your Claude Code agents come to life as animated characters",
  "version": "2.0.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pablodelucca/pixel-agents"
  },
  "license": "MIT",
  "type": "module",
  "main": "dist/server/index.js",
  "bin": {
    "pixel-agents": "dist/server/index.js"
  },
  "scripts": {
    "build:server": "tsc -p tsconfig.json",
    "build:webview": "cd webview-ui && npm run build",
    "build:assets": "node scripts/copy-assets.cjs",
    "build": "npm run build:server && npm run build:webview && npm run build:assets",
    "dev:server": "tsx --watch src/index.ts",
    "dev:webview": "cd webview-ui && npm run build -- --watch",
    "dev": "npm-run-all -p dev:server dev:webview",
    "start": "node dist/server/index.js",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "generate-assets": "tsx scripts/generate-furniture.ts",
    "import-tileset": "tsx scripts/0-import-tileset.ts"
  },
  "dependencies": {
    "express": "^4.21.0",
    "pngjs": "^7.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@types/express": "^5.0.0",
    "@types/node": "22.x",
    "@types/pngjs": "^6.0.5",
    "@types/ws": "^8.5.14",
    "eslint": "^9.39.2",
    "npm-run-all": "^4.1.5",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.54.0"
  }
}
